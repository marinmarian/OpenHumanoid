{
  "env": {
    "shellEnv": { "enabled": true }
  },
  "gateway": {
    "mode": "local",
    "auth": { "mode": "none" }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "openai/gpt-4.1"
      },
      "workspace": "~/.openclaw/workspace"
    }
  },
  "tools": {
    "exec": {
      "host": "gateway",
      "security": "full",
      "ask": "off"
    }
  },
  "channels": {
    "whatsapp": {
      "dmPolicy": "pairing",
      "allowFrom": ["*"]
    }
  },
  "messages": {
    "tts": {
      "auto": "always",
      "provider": "openai",
      "openai": {
        "model": "tts-1",
        "voice": "alloy"
      }
    }
  }
}
